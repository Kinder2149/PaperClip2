# PaperClip2 - Configuration Backend Firebase Functions
# Copier ce fichier vers .env et remplir avec vos valeurs

# Firebase Project Configuration
FIREBASE_PROJECT_ID=your-project-id

# Development - Émulateurs Firebase (optionnel)
# Décommenter ces lignes pour utiliser les émulateurs locaux
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Production
# Les variables de production sont configurées via Firebase CLI :
# firebase functions:config:set app.max_worlds=10
# firebase functions:config:set app.max_snapshot_size_mb=5

# Configuration de l'application (exemples)
# Ces valeurs sont définies dans le code mais peuvent être surchargées
# MAX_WORLDS=10
# MAX_SNAPSHOT_SIZE_MB=5
