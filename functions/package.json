{
  "name": "paperclip2-functions",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf lib",
    "lint": "echo 'no lint yet'",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth",
    "deploy": "npm run build && firebase deploy --only functions:api",
    "test": "jest --runInBand",
    "test:e2e": "jest --runInBand --detectOpenHandles --forceExit test/e2e/backend"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^7.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.19",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.6.3",
    "uuid": "^9.0.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.jest.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json"
    ],
    "testMatch": [
      "**/test/e2e/backend/**/*test.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/e2e/backend/jest.setup.ts"
    ],
    "verbose": true
  }
}
