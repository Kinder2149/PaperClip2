# PaperClip2 - Configuration Client Flutter
# Copier ce fichier vers .env et remplir avec vos valeurs

# Environnement de l'application
# Valeurs possibles : development, staging, production
APP_ENV=development

# URL de base des Firebase Functions
# Format : https://us-central1-<your-project-id>.cloudfunctions.net/api
# Exemple : https://us-central1-paperclip2-prod.cloudfunctions.net/api
FUNCTIONS_API_BASE=https://us-central1-YOUR-PROJECT-ID.cloudfunctions.net/api

# Configuration Firebase
# Note : Les clés Firebase (API Key, Project ID, etc.) sont gérées par :
# - Android : android/app/google-services.json
# - iOS : ios/Runner/GoogleService-Info.plist
# Ces fichiers sont générés depuis la console Firebase et ne doivent PAS être versionnés.

# Debug (optionnel)
# Activer les logs détaillés en développement
# DEBUG_MODE=true
